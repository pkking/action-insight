{
  "ignorePatterns": [
    {
      "pattern": "^http://localhost"
    }
  ],
  "aliveStatusCodes": [200, 429],
  "httpHeaders": [
    {
      "urls": ["https://docs.github.com/"],
      "headers": {
        "Accept-Encoding": "zstd, br, gzip, deflate"
      }
    }
  ],
  "retryOn429": true,
  "fallbackRetryDelay": "30s",
  "maxRetries": 3
}
